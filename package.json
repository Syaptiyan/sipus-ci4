{
    "private": true,
    "type": "module",
    "scripts": {
        "build:css": "npx @tailwindcss/cli -i public/assets/css/app.css -o public/assets/css/app.min.css --minify",
        "build:js": "cp node_modules/alpinejs/dist/cdn.min.js public/assets/js/alpine.min.js",
        "build": "npm run build:css && npm run build:js",
        "dev:css": "npx @tailwindcss/cli -i public/assets/css/app.css -o public/assets/css/app.min.css --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.1.0",
        "tailwindcss": "^4.1.0"
    },
    "dependencies": {
        "alpinejs": "^3.14.0",
        "chart.js": "^4.5.1",
        "daisyui": "^5.0.0"
    }
}
